# ============================================================
# AXON Protocol — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- Server ---
AXON_HOST=0.0.0.0
AXON_PORT=8000
AXON_DEBUG=false

# --- Database ---
# Leave DATABASE_URL empty to use SQLite (default, local dev)
# Set to postgresql://user:password@host:5432/dbname for production
DB_PATH=./axon.db
DATABASE_URL=

# --- PostgreSQL (production) ---
POSTGRES_PASSWORD=change_me_in_production
# DATABASE_URL=postgresql://axon:change_me_in_production@localhost:5432/axon

# --- Agent Communication ---
OPENCLAW_URL=ws://127.0.0.1:18789

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# --- Protocol Economics ---
COMMISSION_RATE=0.05
MAX_REQUESTS_PER_MINUTE=50
STAKE_PERCENTAGE=0.20

# --- Wallet (Phase 2 — leave empty for Phase 1 simulated) ---
PROTOCOL_WALLET=
PROTOCOL_WALLET_NETWORK=base

# --- Logging ---
# Defaults to ~/axon-protocol/logs on local, /var/log/axon on VPS
LOG_DIR=./logs

# --- Cloudflare Tunnel (optional public URL) ---
# Get token from https://dash.cloudflare.com → Zero Trust → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=
