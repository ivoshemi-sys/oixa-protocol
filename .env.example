# ============================================================
# OIXA Protocol — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- Server ---
OIXA_HOST=0.0.0.0
OIXA_PORT=8000
OIXA_DEBUG=false

# --- Database ---
# Leave DATABASE_URL empty to use SQLite (default, local dev)
# Set to postgresql://user:password@host:5432/dbname for production
DB_PATH=./oixa.db
DATABASE_URL=

# --- PostgreSQL (production) ---
POSTGRES_PASSWORD=change_me_in_production
# DATABASE_URL=postgresql://oixa:change_me_in_production@localhost:5432/oixa

# --- Agent Communication ---
OPENCLAW_URL=ws://127.0.0.1:18789

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# --- Protocol Economics ---
COMMISSION_RATE=0.05
MAX_REQUESTS_PER_MINUTE=0   # 0 = unlimited (recommended for production)
STAKE_PERCENTAGE=0.20

# --- Wallet (Phase 2 — leave empty for Phase 1 simulated) ---
PROTOCOL_WALLET=
PROTOCOL_WALLET_NETWORK=base

# --- Logging ---
# Defaults to ~/oixa-protocol/logs on local, /var/log/oixa on VPS
LOG_DIR=./logs

# --- Blockchain / Base mainnet (Phase 2) ---
# Leave all three empty to run in simulated escrow mode (Phase 1)
# Set all three to enable real USDC transactions on Base

# RPC endpoint for Base mainnet — get one free at https://www.alchemy.com or use public:
BASE_RPC_URL=https://mainnet.base.org
# https://sepolia.base.org  ← for testnet

# Private key of the protocol wallet (controls escrow release/refund + receives commissions)
# NEVER commit the real key. Keep it only in .env (gitignored)
PROTOCOL_PRIVATE_KEY=

# Deployed OIXAEscrow contract address on Base
# Deploy with: cd server && python -m blockchain.deploy
ESCROW_CONTRACT_ADDRESS=

# --- Dispute System ---
# Time window (minutes) after delivery during which the requester can open a dispute
DISPUTE_WINDOW_MINUTES=10
# Fee charged to open a dispute (% of transaction value, 0.10 = 10%)
DISPUTE_FEE_RATE=0.10
# How often the auto-release job runs (seconds)
AUTO_RELEASE_INTERVAL=60

# --- Anthropic API (Claude Arbiter) ---
# Required to enable the automatic Claude arbiter for disputes
# Without this key, disputes must be resolved manually via POST /api/v1/disputes/{id}/resolve
ANTHROPIC_API_KEY=
ARBITER_MODEL=claude-opus-4-6
ARBITER_MAX_TOKENS=1024

# --- Safe Multisig ---
SAFE_ADDRESS=

# --- Daily Spending Limit ---
# Maximum USDC that can be escrowed in a single UTC day (default $50)
DAILY_LIMIT_USD=50.0

# --- Stripe (Crypto Onramp + Issuing) ---
# Get keys from https://dashboard.stripe.com/apikeys
# Onramp requires Stripe Crypto Onramp access (request at dashboard)
# Issuing requires Stripe Issuing access (request separately)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook secrets — get from https://dashboard.stripe.com/webhooks after creating endpoints
# Onramp webhook: POST /api/v1/payments/onramp/webhook
STRIPE_WEBHOOK_SECRET=
# Issuing webhook: POST /api/v1/payments/issuing/webhook
STRIPE_ISSUING_WEBHOOK_SECRET=

# --- Circle CCTP (Cross-Chain Transfer Protocol) ---
# Receive USDC from Ethereum, Arbitrum, Avalanche, Polygon → Base mainnet automatically
# CCTP V2 contracts use the same address on all supported EVM chains (defaults are correct)
CCTP_TOKEN_MESSENGER=0x28b5a0e9c621a5badaa536219b3a228c8168cf5d
CCTP_MESSAGE_TRANSMITTER=0x81D40F21F12A8F0E3252Bccb954D722d4c464B64
CCTP_ATTESTATION_URL=https://iris-api.circle.com
# Optional: per-chain RPC URLs for auto-extracting MessageSent events from burn txs
# Without these, senders must provide message_bytes manually
# Free RPCs: infura.io, alchemy.com, ankr.com (all have free tiers)
ETH_RPC_URL=
ARB_RPC_URL=
AVAX_RPC_URL=
POLYGON_RPC_URL=
SOLANA_RPC_URL=

# --- Coinbase Commerce ---
# Accept USDC from any network via hosted payment pages
# Get API key: https://beta.commerce.coinbase.com/settings/security
COINBASE_COMMERCE_API_KEY=
# Webhook secret: https://beta.commerce.coinbase.com/settings/notifications
# Webhook URL to configure: https://<your-domain>/api/v1/payments/coinbase/webhook
COINBASE_COMMERCE_WEBHOOK_SECRET=

# --- Circle Payments API ---
# Institutional USDC payments + outbound transfers via Circle account
# Get API key: https://app.circle.com/developers/api-keys
# Sandbox: https://api-sandbox.circle.com  |  Production: https://api.circle.com
CIRCLE_API_KEY=
CIRCLE_API_URL=https://api.circle.com
# Webhook URL to configure: https://<your-domain>/api/v1/payments/circle/webhook

# --- Cloudflare Tunnel (optional public URL) ---
# Get token from https://dash.cloudflare.com → Zero Trust → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# --- AgentOps (agent monitoring dashboard) ---
# Get key at: https://app.agentops.ai
AGENTOPS_API_KEY=

# --- Zapier (8,000+ app integrations) ---
# Step 1: Create a "Webhooks by Zapier" Catch Hook Zap → copy URL here
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/YOUR_ID/YOUR_KEY/
# Step 2 (optional): set a secret for HMAC signature verification on inbound webhooks
ZAPIER_WEBHOOK_SECRET=
